---
import { cn } from '../../utils'

const { as: Tag = 'div', class: className, href, heading, subheading, date, icon } = Astro.props
---

<Tag
  class={cn(
    'not-prose block relative rounded-2xl border border-border bg-muted px-5 py-3',
    href && 'transition-all hover:border-foreground/25 hover:shadow-sm',
    className
  )}
  href={href}
>
  <div class='flex flex-col gap-y-1.5'>
    <div class='flex flex-col gap-y-0.5'>
      <h2 class='text-lg font-medium'>{heading}</h2>
      <p class='text-muted-foreground'>{subheading}</p>
      <p class='text-muted-foreground'>{date}</p>
    </div>
    <img class='absolute end-0 z-0 m-0 -my-3 h-full w-1/2 object-cover opacity-40' src={icon} />
    <slot />
  </div>
</Tag>
